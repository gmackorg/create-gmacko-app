{
  "name": "@gmacko/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "create-gmacko-app-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsup src/index.ts --format esm --watch",
    "format": "biome check .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@gmacko/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  }
}
