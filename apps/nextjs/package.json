{
  "name": "@gmacko/nextjs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules playwright-report storybook-static test-results",
    "dev": "pnpm with-env next dev",
    "format": "biome check .",
    "lint": "oxlint .",
    "storybook": "SKIP_ENV_VALIDATION=1 storybook dev -p 6006",
    "storybook:build": "SKIP_ENV_VALIDATION=1 storybook build",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@gmacko/analytics": "workspace:*",
    "@gmacko/api": "workspace:*",
    "@gmacko/auth": "workspace:*",
    "@gmacko/config": "workspace:*",
    "@gmacko/db": "workspace:*",
    "@gmacko/i18n": "workspace:*",
    "@gmacko/monitoring": "workspace:*",
    "@gmacko/ui": "workspace:*",
    "@gmacko/validators": "workspace:*",
    "@sentry/nextjs": "^10.44.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@gmacko/tailwind-config": "workspace:*",
    "@gmacko/tsconfig": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/nextjs-vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "jiti": "^2.6.1",
    "oxlint": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:"
  }
}
