{
  "name": "@gmacko/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./openapi": {
      "types": "./dist/openapi.d.ts",
      "default": "./src/openapi.ts"
    },
    "./versioning": {
      "types": "./dist/versioning.d.ts",
      "default": "./src/versioning.ts"
    },
    "./deprecation": {
      "types": "./dist/middleware/deprecation.d.ts",
      "default": "./src/middleware/deprecation.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules coverage",
    "dev": "tsc",
    "format": "biome check .",
    "lint": "oxlint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@gmacko/auth": "workspace:*",
    "@gmacko/config": "workspace:*",
    "@gmacko/db": "workspace:*",
    "@gmacko/validators": "workspace:*",
    "@trpc/server": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@gmacko/tsconfig": "workspace:*",
    "@gmacko/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "openapi-types": "^12.1.3",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
}
