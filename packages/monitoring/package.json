{
  "name": "@gmacko/monitoring",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "default": "./src/web/index.ts"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "default": "./src/native/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "biome check .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@gmacko/config": "workspace:*",
    "@sentry/nextjs": "^10.44.0",
    "@sentry/react-native": "^8.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@gmacko/tsconfig": "workspace:*",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  }
}
