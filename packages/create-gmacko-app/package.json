{
  "name": "create-gmacko-app",
  "version": "0.1.1",
  "description": "Create a modern SaaS app with Next.js, Expo, ForgeGraph guidance, and agent-native DX defaults",
  "type": "module",
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.32.1"
  },
  "bin": {
    "create-gmacko-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:update": "vitest run --config vitest.e2e.config.ts --update"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "picocolors": "^1.1.1",
    "validate-npm-package-name": "^7.0.2"
  },
  "keywords": [
    "saas",
    "template",
    "nextjs",
    "expo",
    "turborepo",
    "forgegraph",
    "vinext"
  ],
  "homepage": "https://github.com/gmackorg/create-gmacko-app#readme",
  "bugs": {
    "url": "https://github.com/gmackorg/create-gmacko-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gmackorg/create-gmacko-app.git"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "catalog:",
    "@types/validate-npm-package-name": "^4.0.2",
    "execa": "^9.6.1",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
