{
  "name": "create-gmacko-app",
  "private": true,
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "doctor": "./scripts/doctor.sh",
    "setup": "./scripts/setup.sh",
    "bootstrap:local": "./scripts/bootstrap-local.sh",
    "provision": "./scripts/provision.sh",
    "auth:generate": "pnpm -F @gmacko/auth generate",
    "db:generate": "pnpm -F @gmacko/db generate",
    "db:migrate": "pnpm -F @gmacko/db migrate",
    "db:push": "turbo -F @gmacko/db push",
    "db:check": "pnpm -F @gmacko/db check",
    "db:seed": "pnpm -F @gmacko/db seed",
    "db:studio": "turbo -F @gmacko/db studio",
    "forge:init": "forge init --full",
    "forge:doctor": "forge doctor",
    "forge:status": "forge status",
    "forge:diff": "forge diff",
    "forge:apply": "forge apply",
    "forge:pull": "forge pull",
    "forge:stages": "forge stage list",
    "forge:deploy:staging": "forge deploy create staging --wait",
    "forge:deploy:production": "forge deploy create production --wait",
    "trpc:ops": "pnpm --filter @gmacko/trpc-cli exec gmacko-ops",
    "mcp:app": "pnpm --filter @gmacko/mcp-server exec gmacko-mcp",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @gmacko/nextjs...",
    "dev:mobile": "./scripts/dev-mobile.sh",
    "format": "turbo run format",
    "format:check": "biome check .",
    "format:fix": "biome check . --write",
    "lint": "turbo run lint",
    "lint:fix": "oxlint . --fix",
    "lint:ox": "oxlint .",
    "lint:ox:fix": "oxlint . --fix",
    "lint:ws": "pnpm dlx sherif@latest",
    "knip": "knip",
    "check:fast": "pnpm lint && pnpm typecheck",
    "check": "pnpm check:fast && pnpm test && pnpm build",
    "e2e:cli:full": "RUN_E2E=true pnpm --dir packages/create-gmacko-app vitest run src/__tests__/e2e.test.ts",
    "release:cli:dry-run": "mkdir -p .artifacts && cd packages/create-gmacko-app && npm pack --pack-destination ../../.artifacts >/dev/null",
    "check:release": "pnpm --dir packages/create-gmacko-app test && pnpm --dir packages/create-gmacko-app build && pnpm release:cli:dry-run",
    "commitlint": "commitlint --from HEAD~1 --to HEAD",
    "postinstall": "pnpm lint:ws",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && lefthook install || true",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test -- --coverage",
    "e2e": "turbo run e2e",
    "e2e:web": "turbo run e2e -F @gmacko/nextjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter='@gmacko/mcp-server' --filter='@gmacko/trpc-client' && changeset publish",
    "ui-add": "pnpm dlx shadcn@latest add && biome check src --write",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@forgegraph/cli": "^0.3.0",
    "@turbo/gen": "^2.8.18",
    "dotenv-cli": "^11.0.0",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "oxlint": "catalog:",
    "turbo": "^2.8.18",
    "typescript": "catalog:"
  }
}
