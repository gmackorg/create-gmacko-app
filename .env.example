# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# =====================================================
# QUICK LOCAL BOOTSTRAP
# Copy this file to `.env`, then run:
#   pnpm bootstrap:local
# Required for the default local path:
# - DATABASE_URL
# - AUTH_SECRET
# - AUTH_DISCORD_ID / AUTH_DISCORD_SECRET (if using Discord auth)
# Optional for iOS App Store-ready mobile auth:
# - AUTH_APPLE_ID / AUTH_APPLE_SECRET / AUTH_APPLE_BUNDLE_ID
# Optional deployment lanes:
# - CLOUDFLARE_ACCOUNT_ID / CLOUDFLARE_API_TOKEN for `--vinext`
# =====================================================

# =====================================================
# CORE APP ENV
# Needed for the default local path and for ForgeGraph stage secrets
# =====================================================

# --- Database (Postgres) ---
# Run Postgres alongside the app first. Migrate to hosted Postgres later if needed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gmacko_dev"

# Optional stage-specific examples
# STAGING_DATABASE_URL="postgresql://postgres:postgres@staging-db:5432/gmacko_staging"
# PRODUCTION_DATABASE_URL="postgresql://app:secret@postgres.internal:5432/gmacko_prod"

# --- Authentication ---
AUTH_SECRET="supersecret"
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
# AUTH_APPLE_ID="com.yourcompany.yourapp.service"
# AUTH_APPLE_SECRET=""
# AUTH_APPLE_BUNDLE_ID="com.yourcompany.yourapp"


# =====================================================
# WEB APP ENV
# Next.js / TanStack Start specific values
# =====================================================

# --- Analytics (PostHog) ---
# NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Monitoring (Sentry) ---
# NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG="your-org"
# SENTRY_PROJECT_WEB="yourapp-web"

# --- Payments (Stripe) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""


# =====================================================
# MOBILE APP ENV
# Expo dev-client, release builds, and stage-specific values
# =====================================================

# --- Analytics (PostHog) ---
# EXPO_PUBLIC_POSTHOG_KEY="phc_..."
# EXPO_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Monitoring (Sentry) ---
# EXPO_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
# SENTRY_PROJECT_MOBILE="yourapp-mobile"

# --- API URLs ---
# STAGING_API_URL="https://staging-api.yourapp.com"
# PRODUCTION_API_URL="https://api.yourapp.com"

# --- Expo release metadata ---
# EXPO_OWNER="your-expo-account"
# EAS_PROJECT_ID="00000000-0000-0000-0000-000000000000"

# --- RevenueCat / Push ---
# See: https://www.revenuecat.com/docs/getting-started
# See: https://docs.expo.dev/push-notifications/overview/


# =====================================================
# OPTIONAL SERVICE INTEGRATIONS
# Shared packages and app features
# =====================================================

# --- Email (Resend) ---
# RESEND_API_KEY=""

# --- Realtime (Pusher) ---
# PUSHER_APP_ID=""
# PUSHER_KEY=""
# PUSHER_SECRET=""
# PUSHER_CLUSTER=""
# NEXT_PUBLIC_PUSHER_KEY=""
# NEXT_PUBLIC_PUSHER_CLUSTER=""

# --- Storage (UploadThing) ---
# UPLOADTHING_TOKEN=""

# --- MCP Server (AI Integration) ---
# GMACKO_API_URL="http://localhost:3000"
# GMACKO_API_KEY="gmk_..."


# =====================================================
# FORGEGRAPH DEPLOYMENT ENV
# Mirror these into ForgeGraph secrets before the first deploy
# =====================================================

# Required per stage
# DATABASE_URL="postgresql://app:secret@postgres.internal:5432/gmacko_prod"
# AUTH_SECRET="replace-me-in-forgegraph"

# Common optional stage secrets
# NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
# RESEND_API_KEY="re_..."
# STRIPE_SECRET_KEY="sk_live_..."


# =====================================================
# CLOUDFLARE WORKERS ENV
# Only needed for the experimental `--vinext` lane
# =====================================================

# CLOUDFLARE_ACCOUNT_ID="your-account-id"
# CLOUDFLARE_API_TOKEN="your-api-token"


# =====================================================
# OPTIONAL RELEASE / CI INFRA
# =====================================================

# --- Container Registry ---
# DOCKER_REGISTRY="ghcr"  # Options: ghcr, dockerhub, harbor
# DOCKERHUB_USERNAME="your-username"
# DOCKERHUB_TOKEN="dckr_pat_..."
# HARBOR_REGISTRY_URL="harbor.your-company.com"
# HARBOR_USERNAME="robot$your-robot"
# HARBOR_PASSWORD="secret"
# HARBOR_PROJECT="your-project"

# --- Package Publishing ---
# NPM_REGISTRY_URL="https://registry.npmjs.org"
# NPM_TOKEN="npm_..."

# --- SDK Publishing ---
# PUBLISH_PYPI="true"
# PYPI_TOKEN="pypi-..."
# PUBLISH_GO="true"
