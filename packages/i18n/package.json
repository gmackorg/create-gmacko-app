{
  "name": "@gmacko/i18n",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "default": "./src/web/index.tsx"
    },
    "./web/locale-switcher": {
      "types": "./dist/web/locale-switcher.d.ts",
      "default": "./src/web/locale-switcher.tsx"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "default": "./src/native/index.tsx"
    },
    "./messages/*": "./messages/*"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "biome check .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@gmacko/config": "workspace:*",
    "i18next": "^25.8.18",
    "next-intl": "^4.8.3",
    "react-i18next": "^16.5.8"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@gmacko/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "expo-localization": "~55.0.9",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "expo-localization": ">=17.0.0",
    "next": ">=15.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "expo-localization": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  }
}
