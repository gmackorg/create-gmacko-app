{
  "name": "@gmacko/operator-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsup src/index.ts --format esm --watch --dts",
    "format": "biome check .",
    "lint": "oxlint .",
    "test": "vitest run src/__tests__/operator-core.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gmacko/trpc-client": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@gmacko/api": "workspace:*",
    "@gmacko/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
}
