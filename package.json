{
  "name": "create-gmacko-app",
  "private": true,
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "setup": "./scripts/setup.sh",
    "provision": "./scripts/provision.sh",
    "auth:generate": "pnpm -F @gmacko/auth generate",
    "db:generate": "pnpm -F @gmacko/db generate",
    "db:migrate": "pnpm -F @gmacko/db migrate",
    "db:push": "turbo -F @gmacko/db push",
    "db:check": "pnpm -F @gmacko/db check",
    "db:seed": "pnpm -F @gmacko/db seed",
    "db:studio": "turbo -F @gmacko/db studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @gmacko/nextjs...",
    "dev:mobile": "./scripts/dev-mobile.sh",
    "format": "turbo run format",
    "format:check": "biome check .",
    "format:fix": "biome check . --write",
    "lint": "turbo run lint",
    "lint:fix": "oxlint . --fix",
    "lint:ox": "oxlint .",
    "lint:ox:fix": "oxlint . --fix",
    "lint:ws": "pnpm dlx sherif@latest",
    "knip": "knip",
    "commitlint": "commitlint --from HEAD~1 --to HEAD",
    "postinstall": "pnpm lint:ws",
    "prepare": "lefthook install",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test -- --coverage",
    "e2e": "turbo run e2e",
    "e2e:web": "turbo run e2e -F @gmacko/nextjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter='@gmacko/mcp-server' --filter='@gmacko/trpc-client' && changeset publish",
    "ui-add": "pnpm dlx shadcn@latest add && biome check src --write",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@turbo/gen": "^2.8.18",
    "dotenv-cli": "^11.0.0",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "oxlint": "catalog:",
    "turbo": "^2.8.18",
    "typescript": "catalog:"
  }
}
